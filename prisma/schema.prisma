// Prisma schema — система управления заявками на снабжение.
// Хранит пользователей, продукты, единицы, заявки с позициями,
// историю изменения статусов и архив выполненных/удалённых заявок.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

enum OrderItemStatus {
  ACCEPTED
  INVOICE_RECEIVED
  INVOICE_PAID
  SHIPPED
  RECEIVED
  SENT_TO_REQUESTER
  ORDER_CONFIRMED
}

enum Role {
  ADMIN
  HEAD_OF_SUPPLY
  SUPPLY_DEPT
  WAREHOUSE
  REQUESTER
}

model User {
  id                 String                  @id @default(cuid())
  name               String
  email              String                  @unique
  password           String
  mustChangePassword Boolean                 @default(false)
  roles              UserRole[]
  resetRequests      PasswordResetRequest[]
  statusChanges      OrderItemStatusLog[]
  requesterProfile   Requester?              // Профиль заказчика, если роль REQUESTER
  createdOrders      Order[]                 // Заявки, созданные этим пользователем
  sentMessages       Message[]               @relation("SentMessages")
  receivedMessages   Message[]               @relation("ReceivedMessages")
  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @updatedAt
}

model UserRole {
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  role   Role

  @@id([userId, role]) // Составной первичный ключ: один пользователь не может иметь дублирующуюся роль
}

model PasswordResetRequest {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  status     String    @default("PENDING")
  createdAt  DateTime  @default(now())
  resolvedAt DateTime?
}

model Product {
  id     String      @id @default(cuid())
  title  String
  items  OrderItem[]
}

model Unit {
  id     String      @id @default(cuid())
  title  String
  items  OrderItem[]
}

model Requester {
  id     String  @id @default(cuid())
  name   String
  orders Order[]
  user   User?   @relation(fields: [userId], references: [id])
  userId String? @unique
}

model Order {
  id            String              @id @default(cuid())
  requester     Requester           @relation(fields: [requesterId], references: [id])
  requesterId   String
  created       DateTime            @default(now()) @db.Date  // @db.Date — только дата (без времени), т.к. для заявки важна только дата
  items         OrderItem[]
  createdBy     User?               @relation(fields: [createdById], references: [id])  // Кто создал заявку (для REQUESTER — сам заявитель)
  createdById   String?

  @@index([requesterId])
  @@index([createdById])
}

model OrderItem {
  id        String              @id @default(cuid())
  order     Order               @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId   String
  product   Product             @relation(fields: [productId], references: [id])
  productId String
  units     Unit                @relation(fields: [unitId], references: [id])
  unitId    String
  quantity  Float
  comment   String?                         // Комментарий к позиции (необязательный, отображается в таблице)
  status    OrderItemStatus     @default(ACCEPTED)  // Текущий статус — ACCEPTED → ... → RECEIVED → SENT_TO_REQUESTER → ORDER_CONFIRMED
  statusLogs OrderItemStatusLog[]
  confirmToken OrderConfirmToken?  // Токен для публичного подтверждения получения этой позиции

  @@index([orderId])
  @@index([productId])
  @@index([unitId])
}

model OrderItemStatusLog {
  id          String          @id @default(cuid())
  orderItem   OrderItem       @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  orderItemId String
  oldStatus   OrderItemStatus?
  newStatus   OrderItemStatus
  changedBy   User            @relation(fields: [changedById], references: [id])
  changedById String
  changedAt   DateTime        @default(now())

  @@index([orderItemId])
  @@index([changedById])
}

model Message {
  id         String    @id @default(cuid())
  senderId   String
  sender     User      @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  receiverId String
  receiver   User      @relation("ReceivedMessages", fields: [receiverId], references: [id], onDelete: Cascade)
  text       String
  createdAt  DateTime  @default(now())
  readAt     DateTime?

  @@index([senderId])
  @@index([receiverId])
  @@index([receiverId, readAt])
}

model ArchivedOrder {
  id             String   @id @default(cuid())
  originalId     String
  requesterName  String   @map("requester_name")
  orderDate      DateTime @map("order_date") @db.Date
  receivedAt     DateTime @map("received_at")               // Дата получения последней позиции (макс. из статус-логов RECEIVED)
  archivedAt     DateTime @default(now()) @map("archived_at")
  items          Json     // Массив объектов: [{ productTitle, unitTitle, quantity, comment, status }] на момент архивации
  createdById    String?  // Кто создал заявку (для REQUESTER-фильтра) — хранится как String, без FK

  @@index([requesterName])
  @@index([archivedAt])
  @@index([createdById])
  @@map("archived_orders") // snake_case для MariaDB (Prisma по умолчанию использует camelCase)
}

// Токен для публичного подтверждения получения конкретного пункта заявки.
// Генерируется при переводе пункта в SENT_TO_REQUESTER, одноразовый.
model OrderConfirmToken {
  id          String    @id @default(cuid())
  orderItemId String    @unique  // Один токен на один пункт заявки
  orderItem   OrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  token       String    @unique  // Одноразовый токен (hex 32 байта)
  usedAt      DateTime?          // Если использован — дата использования
  createdAt   DateTime  @default(now())

  @@index([token])
  @@index([orderItemId])
}
