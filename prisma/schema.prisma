// Prisma schema — User model with multiple roles via join table

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "mysql"
}

enum OrderItemStatus {
  ACCEPTED
  INVOICE_RECEIVED
  INVOICE_PAID
  SHIPPED
  RECEIVED
}

enum Role {
  ADMIN
  HEAD_OF_SUPPLY
  SUPPLY_DEPT
  WAREHOUSE
  REQUESTER
}

model User {
  id                 String                  @id @default(cuid())
  name               String
  email              String                  @unique
  password           String
  mustChangePassword Boolean                 @default(false)
  roles              UserRole[]
  resetRequests      PasswordResetRequest[]
  statusChanges      OrderItemStatusLog[]
  requesterProfile   Requester?              // Профиль заказчика, если роль REQUESTER
  createdOrders      Order[]                 // Заявки, созданные этим пользователем
  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @updatedAt
}

model UserRole {
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  role   Role

  @@id([userId, role]) // Составной первичный ключ: один пользователь не может иметь дублирующуюся роль
}

model PasswordResetRequest {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  status     String    @default("PENDING")
  createdAt  DateTime  @default(now())
  resolvedAt DateTime?
}

model Product {
  id     String      @id @default(cuid())
  title  String
  items  OrderItem[]
}

model Unit {
  id     String      @id @default(cuid())
  title  String
  items  OrderItem[]
}

model Requester {
  id     String  @id @default(cuid())
  name   String
  orders Order[]
  user   User?   @relation(fields: [userId], references: [id])
  userId String? @unique
}

model Order {
  id          String      @id @default(cuid())
  requester   Requester   @relation(fields: [requesterId], references: [id])
  requesterId String
  created     DateTime    @default(now()) @db.Date
  items       OrderItem[]
  createdBy   User?       @relation(fields: [createdById], references: [id])
  createdById String?
}

model OrderItem {
  id        String              @id @default(cuid())
  order     Order               @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId   String
  product   Product             @relation(fields: [productId], references: [id])
  productId String
  units     Unit                @relation(fields: [unitId], references: [id])
  unitId    String
  quantity  Float
  comment   String?
  status    OrderItemStatus     @default(ACCEPTED)
  statusLogs OrderItemStatusLog[]
}

model OrderItemStatusLog {
  id          String          @id @default(cuid())
  orderItem   OrderItem       @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  orderItemId String
  oldStatus   OrderItemStatus?
  newStatus   OrderItemStatus
  changedBy   User            @relation(fields: [changedById], references: [id])
  changedById String
  changedAt   DateTime        @default(now())
}

model ArchivedOrder {
  id             String   @id @default(cuid())
  originalId     String
  requesterName  String   @map("requester_name")
  orderDate      DateTime @map("order_date") @db.Date
  receivedAt     DateTime @map("received_at")
  archivedAt     DateTime @default(now()) @map("archived_at")
  items          Json
  createdById    String?

  @@map("archived_orders") // snake_case для MariaDB (Prisma по умолчанию использует camelCase)
}
