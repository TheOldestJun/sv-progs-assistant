// Prisma schema — User model with multiple roles via join table

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "mysql"
}

enum Role {
  ADMIN
  HEAD_OF_SUPPLY
  SUPPLY_DEPT
  WAREHOUSE
}

model User {
  id                 String                 @id @default(cuid())
  name               String
  email              String                 @unique
  password           String
  mustChangePassword Boolean                @default(false)
  roles              UserRole[]
  resetRequests      PasswordResetRequest[]
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt
}

model UserRole {
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  role   Role

  @@id([userId, role])
}

model PasswordResetRequest {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  status     String    @default("PENDING")
  createdAt  DateTime  @default(now())
  resolvedAt DateTime?
}

model Product {
  id     String  @id @default(cuid())
  title  String
  orders Order[]
}

model Unit {
  id     String  @id @default(cuid())
  title  String
  orders Order[]
}

model Order {
  id        String   @id @default(cuid())
  createdBy String
  product   Product  @relation(fields: [productId], references: [id])
  productId String
  units     Unit     @relation(fields: [unitId], references: [id])
  unitId    String
  quantity  Float
  notes     String?
  created   DateTime @default(now()) @db.Date
}
